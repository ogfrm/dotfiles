passwd #password change
sudo passwd uname #change that users
sudo passwd -e uname #next time he enters asks to reccreate password
sudo passwd -l uname #lock the account
sudo passwd -u uname #unlock the account
sudo passwd -S uname  # 1-uname 2-PS(has password) LK(locked) NP(no password) 3-pass changed 4 pass change allow 5-Has to change date 6-warning date 8-lock after that days
sudo passwd -x 30 uname # after 30 days password will expire
sudo passwd -d uname   # delete the password
