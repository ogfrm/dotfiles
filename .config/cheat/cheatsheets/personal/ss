Will show all connection
ss -t  # tcp connection
ss -lt # listening tcp connections
ss -ua  # all udp connections
ss -s  # statistic
wait ss -s # refresh every 2 seconds
ss -at '( dport = :22 or sport = :22 )'

ss -tulpn  # used ports
ss -tunap  # all connections
