jq . <file>  # all objects
jq '.team' <file>  # all team objects as list
jq '.team[]' <file>  # all team objects as objects
jq '.team[].name' <file>  # all team objects show only names
jq -r '.team[].name' <file>  # all team objects show only names removes quotes
jq '.team | lengh' <file>  # all team objects show only names removes quotes
jq '.team[] | select(.salary >= 100000)' <file>  # all team objects as objects
jq '.team[] | del(.skils)' <file>  # all team objects as objects
jq --arg n "Dinesh" '.team[] | select(.name == $n)' <file>
jq '.team[] | keys' <file>
jq 'has("skills")'
jq '.team[] | select(.skills | index("Java"))' <file> # find skil includes java

