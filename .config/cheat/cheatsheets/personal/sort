# To sort a file:
sort <file>

# To sort a file by keeping only unique:
sort -u <file>

# To sort a file and reverse the result:
sort -r <file>

# To sort a file randomly:
sort -R <file>

######################################
sort -f <file>
sort -n <file>  #  numeric
sort < file
sort < file >sortedfile
ls / | sort

sort ~/bashrc 
sort -r ~/bashrc #reverse
sort -u ~/bashrc #unique
sort -t : -k 3n /etc/passwd  #sort seperator : sort by 3rd column
-o outfile
sort -R ~/bashrc #random
sort ~/bashrc | uniq
sort ~/bashrc | uniq -u #removes duplicated lines fully
sort ~/bashrc | uniq -d #only return uniq
sort ~/bashrc | uniq -c #shows count
sort ~/bashrc | uniq -c | sort -nr #sort with count
cat /etc/passwd

