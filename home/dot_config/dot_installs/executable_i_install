PM=$(pm_detect)
[[ $EUID -eq 0 ]] && PATH=$(real_home)/.local/bin:$PATH

case "$(uname -m)" in
  x86_64) ARCH=x86_64 ;;
  aarch64|arm64) ARCH=aarch64 ;;
  armv7l|armv7|armhf) ARCH=armv7 ;;
  arm) ARCH=arm ;;
  *) ARCH="" ;;
esac

ISALPINE=false
if grep -qi alpine /etc/os-release 2>/dev/null ||
  (command -v ldd >/dev/null && ldd --version 2>&1 | grep -qi musl); then
  ISALPINE=true
fi

PATTERN_LIST=()
if command -v apt >/dev/null && command -v dpkg >/dev/null; then
  PATTERN_LIST+=( "_${ARCH}.deb" )
  PATTERN_LIST+=( "${ARCH}-unknown-linux-gnu.deb" )
fi
if $ISALPINE; then
  PATTERN_LIST+=("${ARCH}-unknown-linux-musl.tar.gz")
  PATTERN_LIST+=("${ARCH}-unknown-linux-musl.zip")
fi
PATTERN_LIST+=("${ARCH}-unknown-linux-gnu.tar.gz")
PATTERN_LIST+=("${ARCH}-unknown-linux-gnu.zip")
if ! $ISALPINE; then
  PATTERN_LIST+=("${ARCH}-unknown-linux-musl.tar.gz")
  PATTERN_LIST+=("${ARCH}-unknown-linux-musl.zip")
fi
if $ISALPINE; then
  PATTERN_LIST+=("musl-linux-${ARCH}.tar.gz");
  PATTERN_LIST+=("musl-linux-${ARCH}.zip");
fi
PATTERN_LIST+=( "gnu-linux-${ARCH}.tar.gz" )
PATTERN_LIST+=( "gnu-linux-${ARCH}.zip" )
if ! $ISALPINE; then
  PATTERN_LIST+=("musl-linux-${ARCH}.tar.gz");
  PATTERN_LIST+=("musl-linux-${ARCH}.zip");
fi
if $ISALPINE; then
  PATTERN_LIST+=("musl-${ARCH}.tar.gz");
  PATTERN_LIST+=("musl-${ARCH}.zip");
fi
PATTERN_LIST+=( "-linux-${ARCH}.tar.gz" "-linux_${ARCH}.tar.gz" "_Linux_${ARCH}.tar.gz" "-linux-${ARCH}" )
PATTERN_LIST+=( "-linux-${ARCH}.zip" "-linux_${ARCH}.zip" "_Linux_${ARCH}.zip" "-linux-${ARCH}" )

verbose "Package Manager: $PM"
verbose "ARCH           : $ARCH"
verbose "Apps           : ${apps[@]}"
verbose "Pattern List   : ${PATTERN_LIST[@]}"
# echo "${#PATTERN_LIST[@]}" # length

##############################################################################
# main
##############################################################################
# for app in "$@"; do
PKG_APPS=()
for app in "${apps[@]}"; do
  printf "\n${BLUE}==>${NC} %s\n" "$app"

  if ! load_app "$app"; then
    if pm_has_pkg "$app"; then
      CMD=$app
      [[ $INSTALL == true ]] && [[ -n "$(cmd_path)" ]] && continue
      verbose "Added to package manager: $app"
      PKG_APPS+=($app) || true
    fi
    log_warn "Unknown app: $app"
    continue
  fi
  verbose "app=$1 repo=$REPO pkg=$PKG cmd=$CMD method=$METHOD"
  # [[ -n "$CMD" ]] || continue
  if $REMOVE; then
    log_info "Unistalling $app"
    [[ -n "$PKG" ]] && PKG_APPS+=($PKG)
    # [[ -n "$PKG" ]] && pm_remove "$PKG" || true
    if declare -F "${app}_i_uninstall" >/dev/null; then
      log_info "Calling funtion ${app}_i_uninstall "
      [[ $DRY == false ]] && ${app}_i_uninstall || true
    fi
    verbose "Calling cleanup_binary"
    [[ $DRY == false ]] && cleanup_binary || true
    continue
  fi
  # if [[ -n $(cmd_path) ]] && [ "$UPGRADE" = false ]; then continue; fi
  INSTALLED_VERSION=$(cmd_version)
  log_info "installed: ${INSTALLED_VERSION:-none}  path: $(cmd_path)"
  if ! $APP_FORCE && [[ -n $REPO ]]; then
    github_info
    [[ $INSTALLED_VERSION == "uptodate" ]] && continue ;
    if [[ "$METHOD" != "custom" ]]; then
      [[ $INSTALL == true ]] && [[ -z "$INSTALLED_VERSION" ]] && github_install
      [[ $UPGRADE == true ]] && [[ -n "$INSTALLED_VERSION" ]] && github_install
    fi
  fi
# apt install --only-upgrade
  if ($APP_FORCE || [[ -z "$REPO" ]]) && [[ $EUID -eq 0 ]] && [[ -n "$PKG" ]];  then
    [[ "$METHOD" != "custom" ]] && [[ $INSTALL == true ]] && [[ -z "$INSTALLED_VERSION" ]]
    PKG_APPS+=($PKG)
  fi
  if [[ $INSTALL == true ]] && [[ -z "$INSTALLED_VERSION" ]]; then
    if declare -F "${app}_i_install" > /dev/null; then
      log_info "Calling funtion ${app}_i_install "
      [[ $DRY == false ]] && ${app}_i_install
    fi
  elif [[ $UPGRADE == true ]] && [[ -n "$INSTALLED_VERSION" ]]; then
    if declare -F "${app}_i_upgrade" >/dev/null; then
      log_info "Calling funtion ${app}_i_upgrade "
      [[ $DRY == false ]] && ${app}_i_upgrade
    elif declare -F "${app}_i_install" >/dev/null; then
      log_info "Calling funtion ${app}_i_install"
      [[ $DRY == false ]] && ${app}_i_install
    fi
  fi
done
printf "\n${BLUE}==>${NC} %s\n" "PACKAGE MANAGER"
# [[ $EUID -eq 0 ]] || exit 0
[[ $APP_ALL == true ]] && [[ $UPGRADE == true ]] && pm_upgrade_all || true
[[ ${#PKG_APPS[@]} -gt 0 ]] || exit 0
if [[ $REMOVE == true ]]; then
  pm_remove ${PKG_APPS[@]}
  exit 0
fi
[[ $INSTALL == true ]] && pm_install ${PKG_APPS[@]} || true
