##############################################################################
# colors / logging
##############################################################################

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
MAGENTA='\033[0;35m'
NC='\033[0m'

log_info()    { printf "${BLUE}[INFO]${NC} %s\n" "$*"; }
log_success() { printf "${GREEN}[ OK ]${NC} %s\n" "$*"; }
log_warn()    { printf "${YELLOW}[WARN]${NC} %s\n" "$*"; }
log_error()   { printf "${RED}[FAIL]${NC} %s\n" "$*" >&2; }
verbose() {
  [[ $VERBOSE -gt 0 ]] && printf "${MAGENTA}[DEBUG]${NC} %s\n" "$*" >&2 || true
}
verbose2() {
  [[ $VERBOSE -gt 1 ]] && printf "${MAGENTA}[DEBUG]${NC} %s\n" "$*" >&2 || true
}
##############################################################################
# helpers
##############################################################################
real_user() { echo "${SUDO_USER:-$(id -un)}" ; }
real_home() { getent passwd "$(real_user)" | cut -d: -f6 2>/dev/null || echo "$HOME" ; }
cleanup_binary() {
  [[ -z "$CMD" ]] && return
  rm -f "/usr/local/bin/$CMD" "$(real_home)/.local/bin/$CMD" \
    "/usr/local/share/man/man1/$CMD"* "$(real_home)/.local/share/man/man1/$CMD"*
}
cmd_version() {
  local cmd_path=$(cmd_path)
  # [[ -z "$cmd_path" ]] && cmd_path=$(command -v "$CMD" 2>/dev/null)
  if [[ -n "$cmd_path" && -x "$cmd_path" ]]; then
    "$cmd_path" $VERSION_ARG 2>/dev/null | grep -Eo '[0-9]+(\.[0-9]+[a-z]?)+' | head -1 || true
  fi
}
cmd_path() {
  local cmd_path=""
  declare -F "${CMD}_i_cmd" >/dev/null && cmd_path=$(${CMD}_i_cmd)
  [[ -z "$cmd_path" ]] && cmd_path=$(type -P "$CMD" 2>/dev/null)
  # $(command -v $CMD) >/dev/null 2>&1
  # verbose "cmd_path($CMD)=$cmd_path"
  if [[ -n "$cmd_path" && -x "$cmd_path" ]]; then
    echo "$cmd_path"
  fi
}

##############################################################################
# package manager
##############################################################################
pm_detect() {
  local pm
  for pm in apt dnf yum pacman apk; do
    command -v "$pm" >/dev/null && { echo "$pm"; return; }
  done
}

pm_install() {
  log_info "$PM install $*"
  [[ $DRY == true ]] && return || true
  [[ $VERBOSE -eq 0 ]] && exec 5>&1 6>&2 && exec &>/dev/null || true
  # apt install --only-upgrade
  case $PM in
    apt) sudo apt-get update && sudo apt-get install -y "$@" >/dev/null ;;
    dnf) sudo dnf install -y "$@" ;;
    yum) sudo yum install -y "$@" ;;
    pacman) sudo pacman -Sy --noconfirm "$@" >/dev/null ;;
    apk) sudo apk add "$@" >/dev/null ;;
  esac
  [[ $VERBOSE -eq 0 ]] && exec 1>&5 2>&6 || true
}
pm_remove() {
  log_info "$PM remove $*"
  [[ $DRY == true ]] && return || true
  [[ $VERBOSE -eq 0 ]] && exec 5>&1 6>&2 && exec &>/dev/null || true
  case $PM in
    apt) sudo apt remove -fy -qq "$@" ;;
    dnf) sudo dnf remove -y -q "$@" ;;
    yum) sudo yum remove -y "$@" ;;
    pacman) sudo pacman -Rns --noconfirm "$@" ;;
    apk) sudo apk del "$@" ;;
  esac
  [[ $VERBOSE -eq 0 ]] && exec 1>&5 2>&6 || true
}

pm_upgrade_all() {
  log_info "$PM upgrade all"
  [[ $DRY == true ]] && return || true
  [[ $VERBOSE -eq 0 ]] && exec 5>&1 6>&2 && exec &>/dev/null
  case $PM in
    apt) sudo apt-get update -qq && sudo apt-get upgrade -y -qq && sudo apt autoremove -y -qq ;;
    dnf) sudo dnf upgrade -y -q ;;
    yum) sudo yum upgrade -y -q ;;
    pacman) sudo pacman -Syu --noconfirm ;;
    apk) sudo apk upgrade ;;
  esac
  if command -v pipx >/dev/null; then
    pipx upgrade-all --include-injected --pip-args="--upgrade-strategy=eager"
  fi
  [[ $VERBOSE -eq 0 ]] && exec 1>&5 2>&6
}
pm_has_pkg() {
  case $PM in
    apt) apt-cache show "$1" >/dev/null 2>&1 ;;
    dnf|yum) "$PM" info "$1" >/dev/null 2>&1 ;;
    pacman) pacman -Si "$1" >/dev/null 2>&1 ;;
    apk) apk info "$1" >/dev/null 2>&1 ;;
  esac
}
##############################################################################
# github
##############################################################################

git_latest_release() {
  local api="https://api.github.com/repos/$REPO"

  curlj() {
    curl -fsSL --connect-timeout 10 --max-time 30 \
      -H "Accept: application/vnd.github+json" "$1" 2>/dev/null
  }

  pick() {
    jq --arg repo "$REPO" '{
      repo: $repo,
      tag_name,
      name,
      published_at,
      prerelease: (.prerelease // false),
      assets: [.assets[]? | {
        name,
        size,
        download_url,
        browser_download_url,
        content_type
      }]
    }'
  }
  # 1) latest release
  out=$(curlj "$api/releases/latest")
  if echo "$out" | jq -e '.tag_name' >/dev/null 2>&1; then
    echo "$out" | pick
    return 0
  fi
  # 2) releases list
  out=$(curlj "$api/releases")
  if echo "$out" | jq -e 'type=="array"' >/dev/null 2>&1; then
    echo "$out" | jq 'map(select(.draft==false)) | .[0]' | pick
    return 0
  fi
  # 3) tags fallback
  tag=$(curlj "$api/tags" | jq -r '.[0].name // empty')
  if [[ -n "$tag" ]]; then
    out=$(curlj "$api/releases/tags/$tag")
    if echo "$out" | jq -e '.tag_name' >/dev/null 2>&1; then
      echo "$out" | pick
      return 0
    fi
  fi
  # 4) empty result
  jq -n --arg repo "$REPO" '{repo:$repo, tag_name:null, assets:[]}'
}

git_latest_version() {
  if command -v jq >/dev/null; then
    jq -r '.tag_name'
  else
    grep '"tag_name"' | head -1 | cut -d'"' -f4
  fi
}
git_latest_files() {
  if command -v jq >/dev/null 2>&1; then
    jq -r '.assets[].browser_download_url'
  else
    grep '"browser_download_url"' | cut -d'"' -f4
  fi
}
# git_latest_version() { printf '%s\n' "$GIT_RELEASE_JSON" | jq -r '.tag_name' ; }
github_info() {
  [[ -n "$REPO" ]] || return 1
  # verbose "querying github release for $REPO"
  GIT_RELEASE_JSON=$(git_latest_release)
  GIT_LATEST_VERSION=$(git_latest_version <<< "$GIT_RELEASE_JSON")
  GIT_LATEST_FILES=$(git_latest_files <<< "$GIT_RELEASE_JSON")
  log_info "GIT latest version: $GIT_LATEST_VERSION"
  verbose2 "Git Latest files: \n$GIT_LATEST_FILES"
  # if [[ "$UPGRADE" = false ]] && [[ -n "$INSTALLED_VERSION" ]] &&
  if [[ -n "$INSTALLED_VERSION" ]] && [[ "${GIT_LATEST_VERSION#v}" == "${INSTALLED_VERSION#v}" ]]; then
    log_success "$REPO is already up to date"
    INSTALLED_VERSION=uptodate
  fi
}

git_latest_url() {
    local pattern="$1"
    verbose2 "DEBUG: processing pattern $pattern"
    printf '%s\n' "$GIT_RELEASE_JSON" |
      { if command -v jq >/dev/null 2>&1; then
          jq -r --arg p "$pattern" '.assets[].browser_download_url | select(contains($p))'
          # jq -r ".assets[].browser_download_url | select(test(\"$pattern\"))"
        else
          grep '"browser_download_url"' | grep "$pattern" | cut -d'"' -f4
        fi
      }
}
git_find_asset() {
  # verbose "searching release assets"
  local pattern url
  for pattern in "${PATTERN_LIST[@]}"; do
    if [[ "$pattern" == *.deb ]] && [[ "$METHOD" != "git_tar" ]] ; then
      url=$(git_latest_url "$pattern" | grep -v -- '-musl' | head -1 )
      [[ -n "$url" ]] && { echo "$url"; return; }
      url=$(git_latest_url "${pattern//x86_64/amd64}" | grep -v -- '-musl' | head -1 )
      [[ -n "$url" ]] && { echo "$url"; return; }
    elif [[ "$pattern" == *.gz ]] && [[ "$METHOD" == "git_tar" ]] ; then
      url=$(git_latest_url "$pattern" | head -n1)
      [[ -n "$url" ]] && { echo "$url"; return; }
      url=$( git_latest_url "${pattern//x86_64/amd64}" | head -n1 )
      [[ -n "$url" ]] && { echo "$url"; return; }
    elif [[ "$METHOD" != "git_tar" ]] ; then
      url=$(git_latest_url "$pattern" | head -n1)
      [[ -n "$url" ]] && { echo "$url"; return; }
      url=$( git_latest_url "${pattern//x86_64/amd64}" | head -n1 )
      [[ -n "$url" ]] && { echo "$url"; return; }
    fi
  done
}
# curl -i https://api.github.com/rate_limit
github_install() {
  local tmp url bin
  url=$(git_find_asset)
  verbose "selected asset: $url"
  [[ -n "$url" ]] || return 1
  tmp=$(mktemp -d) && trap 'rm -rf "$tmp"' RETURN
  log_info "installing from $REPO -> $(basename "$url")"
  [[ $DRY == true ]] && return || true
  case "$url" in
    *.deb)
      curl -fsSL "$url" -o "$tmp/pkg.deb"
      sudo dpkg -i "$tmp/pkg.deb" >/dev/null 2>&1
      sudo apt-get install -fy >/dev/null 2>&1
      log_success "$CMD $(cmd_version) installed from deb"
      return
      ;;
    *.tar.gz)
      curl -fsSL "$url" -o "$tmp/pkg.tar.gz"
      tar -xzf "$tmp/pkg.tar.gz" -C "$tmp"
      ;;
    *.zip)
      curl -fsSL "$url" -o "$tmp/pkg.zip"
      gunzip -c "$tmp/pkg.zip" -c > "$tmp/$CMD"
      ;;
    *.gz)
      curl -fsSL "$url" -o "$tmp/pkg.gz"
      gunzip -c "$tmp/pkg.gz" -c > "$tmp/$CMD"
      chmod +x "$tmp/$CMD"
    ;;
    *)
      curl -fsSL "$url" -o "$tmp/$CMD"
      chmod +x "$tmp/$CMD"
      ;;
  esac

  bin=$(find "$tmp" -type f -name "$CMD" | head -n1)
  [[ -f "$bin" ]] || bin=$(find "$tmp" -type f -perm -111 ! -name '*.so*' | head -n1)
  [[ -n "$bin" ]] || { log_warn "  No executable found in archive"; return 1; }
  mkdir -p "$INSTALL_DIR"
  install -m755 "$bin" "$INSTALL_DIR/$CMD"
  # chmod 755 "$INSTALL_BIN" &&  sudo chown root:root "$INSTALL_DIR" && mv "$INSTALL_DIR" "$INSTALL_DIR/$CMD"
  log_success "$CMD $(cmd_version) -> $INSTALL_DIR/$CMD"
}

##############################################################################
# options
##############################################################################
usage() {
  cat <<EOF
usage: $0 [options] app...

Options:
  -u, --remove
  -g, --upgrade
  -i, --install
  --app-force
  -h, --help

Apps:
$(printf '  %s\n' "${!APPS[@]}" | sort)

Special:
  all      install all apps
EOF
  exit 0
}

REMOVE=false UPGRADE=false INSTALL=false APP_FORCE=false VERBOSE=0 DRY=false NERDFONTS=""
while (($#)); do
  case "$1" in
    -u|--remove) REMOVE=true ;;
    -g|--upgrade) UPGRADE=true ;;
    -i|--install) INSTALL=true ;;
    -v|--verbose) VERBOSE=1 ;;
    -vv) VERBOSE=2 ;;
    --dry) DRY=true ;;
    --app-force) APP_FORCE=true ;;
    --fonts) NERDFONTS=$2 && shift ;;
    -h|--help) usage ;;
    -*) echo "unknown option: $1"; exit 0 ;;
    *) break ;;
  esac
  shift
done
APP_ALL=false
apps=("$@")
if ((${#apps[@]} == 1)) && [[ ${apps[0]} == all ]]; then
  APP_ALL=true
  apps=("${!APPS[@]}")
fi
if ! $INSTALL && ! $UPGRADE && ! $REMOVE; then
    INSTALL=true
fi
