load_app() {
  [[ -v "APPS[$1]" ]] || return 1
  IFS=: read -r \
    REPO PKG CMD VERSION_ARG METHOD \
    <<< "${APPS[$1]}"
  VERSION_ARG="${VERSION_ARG:---version}"
}
