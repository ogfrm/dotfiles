##############################################################################
# options
##############################################################################

REMOVE=false UPGRADE=false APP_FORCE=false INSTALL=false

usage() {
  cat <<EOF
usage: $0 [options] app...

Options:
  -u, --remove
  -g, --upgrade
  -i, --install
  --app-force
  -h, --help

Apps:
$(printf '  %s\n' "${!APPS[@]}" | sort)

Special:
  all      install all apps
EOF
  exit 0
}

while (($#)); do
  case "$1" in
    -u|--remove) REMOVE=true ;;
    -g|--upgrade) UPGRADE=true ;;
    -i|--upgrade) INSTALL=true ;;
    --app-force) APP_FORCE=true ;;
    -h|--help) usage ;;
    -*) echo "unknown option: $1"; exit 1 ;;
    *) break ;;
  esac
  shift
done
if ! $INSTALL && ! $UPGRADE && ! $REMOVE; then
    INSTALL=true
fi
apps=("$@")
if ((${#apps[@]} == 1)) && [[ ${apps[0]} == all ]]; then
  apps=("${!APPS[@]}")
fi

##############################################################################
# package manager
##############################################################################
detect_pm() {
  local pm
  for pm in apt dnf yum pacman apk; do
    command -v "$pm" >/dev/null && { echo "$pm"; return; }
  done
}

PM=$(detect_pm)

pm_install() {
  echo "  $PM install $@  "
  case $PM in
    apt) sudo apt update && sudo apt install -y "$@" ;;
    dnf) sudo dnf install -y "$@" ;;
    yum) sudo yum install -y "$@" ;;
    pacman) sudo pacman -Sy --noconfirm "$@" ;;
    apk) sudo apk add "$@" ;;
  esac
}
pm_remove() {
  echo "  $PM remove $@  "
  case $PM in
    apt) sudo apt remove -fy -qq "$@" >/dev/null 2>&1 ;;
    dnf) sudo dnf remove -y -q "$@" >/dev/null 2>&1 ;;
    yum) sudo yum remove -y "$@" >/dev/null 2>&1 ;;
    pacman) sudo pacman -Rns --noconfirm "$@" >/dev/null 2>&1 ;;
    apk) sudo apk del "$@" >/dev/null 2>&1 ;;
  esac
}

pm_upgrade_all() {
  echo "  $PM upgrade all $@  "
  case $PM in
    apt) sudo apt-get update -qq && apt-get upgrade -y -qq >/dev/null ;;
    dnf) sudo dnf upgrade -y -q ;;
    yum) sudo yum upgrade -y -q ;;
    pacman) sudo pacman -Syu --noconfirm ;;
    apk) sudo apk upgrade ;;
  esac
}

##############################################################################
# platform
##############################################################################

case "$(uname -m)" in
  x86_64) ARCH=x86_64 ;;
  aarch64|arm64) ARCH=aarch64 ;;
  armv7l|armv7|armhf) ARCH=armv7 ;;
  arm) ARCH=arm ;;
  *) ARCH="" ;;
esac

ISALPINE=false
if grep -qi alpine /etc/os-release 2>/dev/null ||
  (command -v ldd >/dev/null && ldd --version 2>&1 | grep -qi musl); then
  ISALPINE=true
fi

PATTERN_LIST=()
if command -v apt >/dev/null && command -v dpkg >/dev/null; then
  PATTERN_LIST+=( "_${ARCH}.deb" )
fi
if $ISALPINE; then PATTERN_LIST+=("${ARCH}-unknown-linux-musl.tar.gz"); fi
PATTERN_LIST+=("${ARCH}-unknown-linux-gnu.tar.gz")
if ! $ISALPINE; then PATTERN_LIST+=("${ARCH}-unknown-linux-musl.tar.gz"); fi
if $ISALPINE; then PATTERN_LIST+=("musl-linux-${ARCH}.tar.gz"); fi
PATTERN_LIST+=( "gnu-linux-${ARCH}.tar.gz" )
if ! $ISALPINE; then PATTERN_LIST+=("musl-linux-${ARCH}.tar.gz"); fi
PATTERN_LIST+=( "-linux-${ARCH}.tar.gz" "_Linux_${ARCH}.tar.gz" "-linux-${ARCH}" )

