##############################################################################
# helpers
##############################################################################

real_user() { echo "${SUDO_USER:-$(id -un)}" ; }
real_home() { getent passwd "$(real_user)" | cut -d: -f6 2>/dev/null || echo "$HOME" ; }
cleanup_binary() {
  rm -f "/usr/local/bin/$CMD" "$(real_home)/.local/bin/$CMD" \
    "/usr/local/share/man/man1/$CMD"* "$(real_home)/.local/share/man/man1/$CMD"*
}
# installed_version() {
#   command -v "$CMD" >/dev/null 2>&1 || return 0
#   "$CMD" $VERSION_ARG 2>/dev/null | grep -Eo '[0-9]+(\.[0-9]+[a-z]?)+' | head -1
# }
cmd_version() {
  local cmd_path=$(cmd_path)
  # [[ -z "$cmd_path" ]] && cmd_path=$(command -v "$CMD" 2>/dev/null)
  if [[ -n "$cmd_path" && -x "$cmd_path" ]]; then
    "$cmd_path" $VERSION_ARG 2>/dev/null | grep -Eo '[0-9]+(\.[0-9]+[a-z]?)+' | head -1
  fi
}
cmd_path() {
  local cmd_path=""
  declare -F "${CMD}_i_cmd" >/dev/null && cmd_path=$(${CMD}_i_cmd)
  [[ -z "$cmd_path" ]] && cmd_path=$(type -P "$CMD" 2>/dev/null)
  # $(command -v $CMD) >/dev/null 2>&1
  if [[ -n "$cmd_path" && -x "$cmd_path" ]]; then
    echo "$cmd_path"
  fi
}
##############################################################################
# github
##############################################################################

latest_release() { curl -fsSL "https://api.github.com/repos/$REPO/releases/latest" ;}
latest_version() {
  if command -v jq >/dev/null; then
    jq -r '.tag_name'
  else
    grep '"tag_name"' | head -1 | cut -d'"' -f4
  fi
}
# git_latest_version() { printf '%s\n' "$RELEASE_JSON" | jq -r '.tag_name' ; }


git_latest_url() {
    local pattern="$1"
    printf '%s\n' "$RELEASE_JSON" |
      { if command -v jq >/dev/null 2>&1; then
          jq -r --arg p "$pattern" '.assets[].browser_download_url | select(contains($p))'
          # jq -r ".assets[].browser_download_url | select(test(\"$pattern\"))"
        else
          grep '"browser_download_url"' | grep "$pattern" | cut -d'"' -f4
        fi
      }
}
find_asset() {
  local pattern url
  for pattern in "${PATTERN_LIST[@]}"; do
    if [[ "$pattern" == *.deb ]] && [[ "$METHOD" != "git_tar" ]] ; then
      url=$(git_latest_url "$pattern" | grep -v -- '-musl' | head -1 )
      [[ -n "$url" ]] && { echo "$url"; return; }
      url=$(git_latest_url "${pattern//x86_64/amd64}" | grep -v -- '-musl' | head -1 )
      [[ -n "$url" ]] && { echo "$url"; return; }
    elif [[ "$pattern" == *.gz ]] && [[ "$METHOD" == "git_tar" ]] ; then
      url=$(git_latest_url "$pattern" | head -n1)
      [[ -n "$url" ]] && { echo "$url"; return; }
      url=$( git_latest_url "${pattern//x86_64/amd64}" | head -n1 )
      [[ -n "$url" ]] && { echo "$url"; return; }
    elif [[ "$METHOD" != "git_tar" ]] ; then
      url=$(git_latest_url "$pattern" | head -n1)
      [[ -n "$url" ]] && { echo "$url"; return; }
      url=$( git_latest_url "${pattern//x86_64/amd64}" | head -n1 )
      [[ -n "$url" ]] && { echo "$url"; return; }
    fi
  done
}

github_install() {
  local mode="${1:?mode required: install|upgrade}"
  local tmp url bin
  [[ -n "$REPO" ]] || return 1
  RELEASE_JSON=$(latest_release)
  LATEST_VERSION=$(latest_version <<< "$RELEASE_JSON")
  INSTALLED_VERSION=$(cmd_version)
  echo "  Installed: ${INSTALLED_VERSION:-none}"
  echo "  Latest:    $LATEST_VERSION"

  # if [[ "$UPGRADE" = false ]] && [[ -n "$INSTALLED_VERSION" ]] &&
  # if [[ -n "$INSTALLED_VERSION" ]] && [[ "${LATEST_VERSION#v}" == "${INSTALLED_VERSION#v}" ]]; then
  #   echo "  $REPO is already up to date."
  #   SKIPINSTALL=true
  #   return
  # fi
  if [[ "$mode" == "install" ]]; then
    [[ -n "$INSTALLED_VERSION" ]] && return 0
  fi

  if [[ "$mode" == "upgrade" ]]; then
    [[ -z "$INSTALLED_VERSION" ]] && return 0
  fi

  if [[ -n "$INSTALLED_VERSION" && "${LATEST_VERSION#v}" == "${INSTALLED_VERSION#v}" ]]; then
    echo "Up to date"
    return 0
  fi
  [[ "$METHOD" == "custom" ]] && return
  url=$(find_asset)

  # url=$(find_asset)
  [[ -n "$url" ]] || return 1
  tmp=$(mktemp -d) && trap 'rm -rf "$tmp"' RETURN
  echo "  Installing from $REPO ... $(basename $url)"
  case "$url" in
    *.deb)
      curl -fsSL "$url" -o "$tmp/pkg.deb"
      sudo dpkg -i "$tmp/pkg.deb" >/dev/null 2>&1
      sudo apt-get install -fy >/dev/null 2>&1
      echo "  Installed DEB $CMD version $(cmd_version) -> $INSTALL_DIR/$CMD"
      return
      ;;
    *.tar.gz)
      curl -fsSL "$url" -o "$tmp/pkg.tar.gz"
      tar -xzf "$tmp/pkg.tar.gz" -C "$tmp"
      ;;
    *)
      curl -fsSL "$url" -o "$tmp/$CMD"
      chmod +x "$tmp/$CMD"
      ;;
  esac

  bin=$(find "$tmp" -type f -name "$CMD" | head -n1)
  [[ -f "$bin" ]] || bin=$(find "$tmp" -type f -perm -111 ! -name '*.so*' | head -n1)
  [[ -n "$bin" ]] || { echo "  No executable found in archive"; return 1; }
  mkdir -p "$INSTALL_DIR"
  install -m755 "$bin" "$INSTALL_DIR/$CMD"
  # chmod 755 "$INSTALL_BIN" &&  sudo chown root:root "$INSTALL_DIR" && mv "$INSTALL_DIR" "$INSTALL_DIR/$CMD"
  echo "  Installed $CMD version $(cmd_version) -> $INSTALL_DIR/$CMD"
}

##############################################################################
# main
##############################################################################
# for app in "$@"; do
for app in "${apps[@]}"; do
  load_app "$app" || {
    echo "Unknown app: $app"
    continue
  }

  echo "$app......"
  [[ -n "$CMD" ]] || continue
  if $REMOVE; then
    [[ -n "$PKG" ]] && pm_remove "$PKG" || true
    cleanup_binary
    declare -F "${app}_i_uninstall" >/dev/null || continue
    ${app}_i_uninstall ;
    continue
  fi
  SKIPINSTALL=false

  installed=false
  cmd_path >/dev/null 2>&1 && installed=true

  action=""
  if $INSTALL && ! $installed; then
    action="install"
  elif $UPGRADE && $installed; then
    action="upgrade"
  fi
  [[ -z "$action" ]] && continue
  github_install "$action" || true

  [[ $SKIPINSTALL == true ]] && continue ;

  if ($APP_FORCE || [[ -z "$REPO" ]]) && [[ $EUID -eq 0 ]] && [[ -n "$PKG" ]] >/dev/null 2>&1; then
    pm_install "$PKG"
  fi
  declare -F "${app}_i_install" >/dev/null || continue
  ${app}_i_install ;

done
