mkdir ~/dotfiles
cp ~/.zshrc ~/dotfiles/
mv ~/.zshrc ~/.zshrc.bak
cd ~/dotfiles
stow .
stow --adopt .   # will copy org files to dotfiles overwrite then make link
# OR by project
mkdir ~/dotfiles/tmux/.config/tmux
mkdir ~/neovim/.config/nvim
stow --target=/home/venthur tmux
# OR all
stow --target=/home/venthur */

