# Replaceses ifconfig and route command (it can do all they can do and more)
ip addr
ip addr | grep eth0
ip route                # router ip
ip a                    # ip addr show #  get ip adress
sudo ip addr add 192.168.0.123/24 dev wlo1
sudo ip addr del 192.168.0.123/24 dev wlo1
ip route show
sudo ip route add 192.168.1.0/24 via 192.168.1.1 dev wlo1
sudo ip route del 192.168.1.0/24
- View statistics: `ip -s link show <interface>`
- Dynamic updates: `watch "ip -s link show <interface>"`
- **Example:** Replace `<interface>` with your device name (e.g., `wlo1`) to monitor dropped packets, errors, or other statistics.
