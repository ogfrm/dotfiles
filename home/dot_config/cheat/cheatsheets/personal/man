# To convert a man page to pdf:
man -t bash | ps2pdf - bash.pdf

# To view the ascii chart:
man 7 ascii

# To see config:
cat /private/etc/man.conf

########################################
# q search
# g goto top
# S+g goto end
# Sections
       1   Executable programs or shell commands
       2   System calls (functions provided by the kernel)
       3   Library calls (functions within program libraries)
       4   Special files (usually found in /dev)
       5   File formats and conventions, e.g. /etc/passwd
       6   Games
       7   Miscellaneous (including macro packages and conventions), e.g. man(7), groff(7), man-pages(7)
       8   System administration commands (usually only for root)
       9   Kernel routines [Non standard]
ls /user/share/man
# shows the section 5 some cmds has more sections there 9 secs
man 5 passwd

# built in command dont have man page like cd
man bulitins


man man

man -f ls  # shows all man includes ls same as    whatif ls
man 1 ls   # shows man in 1
man 1p ls  # shows man in 1p
man -w ls   # shows the man file for ls
man -k "install"  # shows all man includes install
man --locale tr man
man -P less mv   # uses less command as pages
man -P "nvim +Man!" mv  # uses nvim as viewer
export MANPAGER="nvim +Man!"  # put it in bashrc
