### CAL ###
# sudo apt install ncal
cal
cal -y                  # Display Calendar for Entire Current Year**:
cal -Y                  # Next 12 months
cal -m                  # start of day Monday
cal 1982                # Year 1982
cal 8 1982              # cal [month] [year]
cal -3                  # **Show a Three-Month Calendar (Current, Previous, and Next Months)**
cal -w                  # week numbers