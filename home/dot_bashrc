# https://tiswww.case.edu/php/chet/bash/bashref.html#Special-Parameters

# Note: bind used instead of sticking these in .inputrc
bind "set bell-style visible"; # Disable the bell
bind "set completion-ignore-case on"; # Ignore case on auto-completion
bind "set show-all-if-ambiguous On";

export HISTTIMEFORMAT="%F %T " # add timestamp to history "%Y-%m-%d %T "
# Don't put duplicate lines in the history and do not add lines that start with a space
export HISTCONTROL=erasedups:ignoredups:ignorespace

# more synchronized command history when working with multiple Bash terminals simultaneously.
# to manage the command history across multiple terminal sessions. Without this, history is only saved at session exits
# PROMPT_COMMAND:  specifies a commands to be executed just before Bash displays a new prompt.
# history -a Write current history to file;
# history -r: read from other sessions history appends its contents to the in-memory history
PROMPT_COMMAND='history -a; history -r;'

### SHOPT ## DT
shopt -s autocd # change to named directory
shopt -s cdspell # autocorrects cd misspellings
shopt -s cmdhist # save multi-line commands in history as single line
shopt -s dotglob
shopt -s expand_aliases # expand aliases

alias h='history'
# alias reload="source ~/.bashrc"
alias reload="exec bash"
alias ep="$EDITOR $HOME/.bashrc"

# directory pushd  history with d see and jump back with 1-9 or 1-100
alias d='dirs -v'
for index in {1..9}; do alias "$index"="pushd +${index}";unset index; done

for f in ~/.config/.rc/sh_*.sh; do  source "$f"; done
# [ -f ~/.config/.rc/shlast_*.sh ] && for f in ~/.config/.rc/shlast_*.sh; do  source "$f"; done || echo
for f in ~/.config/.rc/shlast_*.sh; do  source "$f"; done

